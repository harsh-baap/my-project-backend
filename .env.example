# Environment variables for Python Flask server
FLASK_PORT=5000
FLASK_DEBUG=False
FLASK_ENV=production

# Database
MONGO_URI=mongodb://localhost:27017/project
SESSION_SECRET=your_session_secret_key_here

# Docker Compose only
MONGO_PASSWORD=admin123

# Upload settings
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=outputs
MAX_FILE_SIZE=524288000

# Models path
MODELS_PATH=DataModel/models

# API settings
API_HOST=0.0.0.0
API_PORT=5000
